# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
BACKEND_PUBLIC_URL=http://localhost:5000

# PostgreSQL / Neon (required)
DATABASE_URL=postgresql://user:password@host.neon.tech/database?sslmode=require

# Authentication (replace with long random values in Railway)
JWT_SECRET=replace_with_a_long_random_access_token_secret
JWT_REFRESH_SECRET=replace_with_a_different_long_random_refresh_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Idempotent seed logins
ADMIN_EMAIL=admin@darcystaffing.com
ADMIN_PASSWORD=Admin@123456
SUPER_ADMIN_EMAIL=superadmin@darcystaffing.com
SUPER_ADMIN_PASSWORD=SuperAdmin@123456
CLIENT_EMAIL=client@darcystaffing.com
CLIENT_USERNAME=unza_xwear
CLIENT_PASSWORD=@Hadi123

# OpenRouter free router. The API key is optional because a deterministic local
# CV scorer/assistant is used when OpenRouter is unavailable.
OPENROUTER_API_KEY=paste_your_free_openrouter_api_key
OPENROUTER_MODEL=openrouter/free

# Stripe (only required for real checkout/billing flows)
STRIPE_SECRET_KEY=paste_your_stripe_test_secret
STRIPE_WEBHOOK_SECRET=paste_your_webhook_secret
STRIPE_PD_PRICE_ID=paste_your_pd_price_id
STRIPE_LINEHAUL_PRICE_ID=paste_your_linehaul_price_id

# S3 (recommended on Railway because its local filesystem is ephemeral)
AWS_ACCESS_KEY_ID=paste_your_aws_access_key
AWS_SECRET_ACCESS_KEY=paste_your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=darcy-staffing-docs

# Firebase (optional)
FIREBASE_PROJECT_ID=darcy-staffing
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\npaste_here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@darcy-staffing.iam.gserviceaccount.com

# SMTP (optional; notifications still work when email is unavailable)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=paste_smtp_username
SMTP_PASS=paste_smtp_password
EMAIL_FROM="Darcy Staffing <noreply@darcystaffing.com>"
